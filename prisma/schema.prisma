generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GradeStatus {
  ACTIVE
  SOON
}

enum Region {
  ANDIJAN
  BUKHARA
  JIZZAKH
  KASHKADARYA
  NAVOI
  NAMANGAN
  SAMARKAND
  SURKHANDARYA
  SYRDARYA
  TASHKENT_REGION
  FERGANA
  KHOREZM
  KARAKALPAKSTAN
}

// Шаги регистрации в Telegram-боте (см. src/bot/bot.ts). Заводится явно на NAME
// при создании пользователя через /start; пользователи, созданные другими путями
// (например, автологин в Mini App), по умолчанию считаются уже DONE.
enum RegistrationStep {
  NAME
  AWAITING_NAME_INPUT
  REGION
  DONE
}

enum LessonCardType {
  MAIN_IDEA
  EXPLANATION
  ILLUSTRATION
  CONNECTION
  COMMON_MISTAKE
  MINI_QUESTION
  KEY_TERMS
  SUMMARY
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

model User {
  id               String           @id @default(cuid())
  telegramId       String           @unique
  firstName        String
  username         String?
  region           Region?
  registrationStep RegistrationStep @default(DONE)
  createdAt        DateTime         @default(now())

  lessonProgress  UserLessonProgress[]
  mistakes        UserMistake[]
  repetitionItems RepetitionItem[]
  streak          UserStreak?
}

model Grade {
  id     String      @id @default(cuid())
  number Int         @unique
  status GradeStatus @default(SOON)

  topics Topic[]
}

// Предметный раздел для вкладки "По темам" — не привязан к классу, собирает
// темы одного предмета (напр. Ботаника) из всех классов сразу.
model TopicCategory {
  id       String @id @default(cuid())
  name     String
  icon     String
  colorKey String
  order    Int    @default(0)

  topics Topic[]
}

// Тема уровня параграфа учебника — всегда привязана к одному классу.
// Узел вкладки "По классам" (класс → главы → темы) и, через categoryId,
// узел вкладки "По темам" (раздел → темы из всех классов).
model Topic {
  id           String         @id @default(cuid())
  gradeId      String
  grade        Grade          @relation(fields: [gradeId], references: [id])
  categoryId   String?
  category     TopicCategory? @relation(fields: [categoryId], references: [id])
  chapterTitle String
  chapterOrder Int
  title        String
  order        Int

  lessons         Lesson[]
  connectionsFrom TopicConnection[] @relation("FromTopic")
  connectionsTo   TopicConnection[] @relation("ToTopic")

  @@unique([gradeId, order])
}

model Lesson {
  id        String  @id @default(cuid())
  topicId   String
  topic     Topic   @relation(fields: [topicId], references: [id])
  title     String
  order     Int     @default(0)
  // Feature-флаг: пока false, урок не отдаётся ни одним API-роутом и не всплывает
  // ни в одном списке — не только скрыт из UI, но и недоступен по прямой ссылке.
  published Boolean @default(false)

  cards           LessonCard[]
  questions       Question[]
  progress        UserLessonProgress[]
  repetitionItems RepetitionItem[]
}

model LessonCard {
  id       String         @id @default(cuid())
  lessonId String
  lesson   Lesson         @relation(fields: [lessonId], references: [id])
  type     LessonCardType
  order    Int
  title    String?
  content  String
  svgKey   String?
  // Только для type=ILLUSTRATION со схемами: подпись/оговорка под схемой.
  caption      String?
  // Служебная трассировка к источнику — никогда не сериализуется в клиентский API-ответ.
  canonicalId  String?
  sourcePages  String?
}

// Связи между темами — для карточек "Связь с другой темой" и будущей карты знаний
model TopicConnection {
  id          String @id @default(cuid())
  fromTopicId String
  fromTopic   Topic  @relation("FromTopic", fields: [fromTopicId], references: [id])
  toTopicId   String
  toTopic     Topic  @relation("ToTopic", fields: [toTopicId], references: [id])
  description String
}

model Question {
  id       String       @id @default(cuid())
  lessonId String
  lesson   Lesson       @relation(fields: [lessonId], references: [id])
  text     String
  order    Int
  type     QuestionType @default(SINGLE_CHOICE)
  // Показывается ученику после ответа как «Объяснение».
  note     String?
  // Служебная трассировка к источнику — никогда не сериализуется в клиентский API-ответ.
  canonicalId String?
  sourcePages String?

  options  QuestionOption[]
  hints    Hint[]
  mistakes UserMistake[]
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  text       String
  isCorrect  Boolean  @default(false)
  order      Int
}

model Hint {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  order      Int
  text       String
}

model UserLessonProgress {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  lessonId         String
  lesson           Lesson    @relation(fields: [lessonId], references: [id])
  currentCardIndex Int       @default(0)
  completed        Boolean   @default(false)
  completedAt      DateTime?
  updatedAt        DateTime  @updatedAt

  @@unique([userId, lessonId])
}

model UserMistake {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  timesWrong  Int      @default(0)
  lastWrongAt DateTime @default(now())

  @@unique([userId, questionId])
}

// Простое интервальное повторение (Leitner): успех -> intervalDays удваивается, ошибка -> сброс на 1
model RepetitionItem {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id])
  dueAt        DateTime
  intervalDays Int      @default(1)

  @@unique([userId, lessonId])
}

model UserStreak {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])
  currentStreak  Int       @default(0)
  lastActiveDate DateTime?
}
